    "ConvexPanel - Main embeddable component",
    "ConvexPanelShadow - Shadow DOM variant",
    "HealthView - Health metrics view component",
    "DataView - Data browser view component",
    "FunctionsView - Functions explorer view component",
    "LogsView - Logs viewer component",
    "FilesView - File storage manager component",
    "SettingsView - Settings panel component",
    "useOAuth() - OAuth authentication hook",
    "useTheme() - Theme management hook",
    "useComponents() - Components registry hook",
    "buildAuthorizationUrl() - OAuth URL builder",
    "exchangeCodeForToken() - OAuth token exchange",
    "handleOAuthCallback() - OAuth callback handler",
    "fetchFailureRate() - Metrics API for failure rates",
    "fetchCacheHitRate() - Metrics API for cache performance",
    "fetchLatencyPercentiles() - Metrics API for latency",
    "npx convex-panel setup - CLI setup command"
