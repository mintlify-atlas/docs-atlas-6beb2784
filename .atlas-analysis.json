  "keyFeatures": [
    "Real-time data browser with CRUD operations",
    "Live log streaming and historical search",
    "Health metrics and performance monitoring",
    "Function runner with code inspection",
    "Interactive schema visualizer with Git integration",
    "File storage management",
    "Cross-platform support (Desktop, Mobile, Web, Raycast)",
    "OAuth and deploy key authentication",
    "Dark/light theme support",
    "Framework-agnostic React components"
